{
  "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
  "version": 4,
  "palette": {
    "icon": "#acb0be",
    "prompt": "#6c7086",
    "transient": "#89b4fa",
    "seperator": "#6c7086",
    "success": "#a6e3a1",
    "error": "#f38ba8",

    "path": "#cba6f7",
    "project": "#94e2d5",
    "git": "#89dceb",

    "project:node": "#a6e3a1",
    "project:php": "#b4befe",
    "project:cargo": "#fab387"
  },
  "var": {
    "Seperator": "\uf444",
    "Prompt": "\ue691",
    "Transient": "\uf061",
    "Success": "\uf00c",
    "Error": "\uf00d"
  },
  "final_space": true,
  "transient_prompt": {
    "background": "transparent",
    "foreground": "p:transient",
    "template": "{{ .Var.Transient }} "
  },
  "console_title_template": "{{ .Folder }}",
  "blocks": [
    {
      "type": "prompt",
      "alignment": "left",
      "segments": [
        {
          "type": "text",
          "style": "plain",
          "foreground": "white",
          "foreground_templates": [
            "{{ if eq .Code 0 }}p:success{{ end }}",
            "{{ if ne .Code 0 }}p:error{{ end }}"
          ],
          "template": "({{ if eq .Code 0 }}{{ .Var.Success }}{{ else }}{{ .Var.Error }}{{ end }})"
        },
        {
          "type": "path",
          "style": "plain",
          "foreground": "p:path",
          "template": " <p:seperator>{{ .Var.Seperator }}</> (\ue5fe {{ .Path }})",
          "options": {
            "folder_icon": "\ue5fe",
            "folder_separator_icon": "/",
            "home_icon": "\uf015",
            "style": "folder"
          }
        },
        {
          "type": "project",
          "style": "plain",
          "foreground": "p:project",
          "foreground_templates": [
            "{{ if .Type  }}p:project:{{ .Type }}{{ end }}"
          ],
          "template": "{{ if .Type }} <p:seperator>{{ .Var.Seperator }}</> (\uf487 {{ .Type }}){{ end }}"
        },
        {
          "type": "git",
          "style": "plain",
          "foreground": "p:git",
          "template": " <p:seperator>{{ .Var.Seperator }}</> ({{ .HEAD }})",
          "options": {
            "branch_icon": "\ue725 ",
            "cherry_pick_icon": "\ue29b ",
            "commit_icon": "\uf417 ",
            "fetch_status": false,
            "fetch_upstream_icon": false,
            "merge_icon": "\ue727 ",
            "no_commits_icon": "\uf0c3 ",
            "rebase_icon": "\ue728 ",
            "revert_icon": "\uf0e2 ",
            "tag_icon": "\uf412 "
          }
        }
      ]
    },
    {
      "type": "prompt",
      "alignment": "left",
      "segments": [
        {
          "type": "text",
          "style": "plain",
          "foreground": "p:prompt",
          "template": " {{ .Var.Prompt }}"
        }
      ]
    }
  ]
}
