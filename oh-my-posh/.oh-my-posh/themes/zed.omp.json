{
  "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
  "version": 4,
  "palette": {
    "prompt": "#6c7086",
    "transient": "#89b4fa",
    "seperator": "#6c7086",

    "path": "#cba6f7",
    "git": "#89dceb"
  },
  "var": {
    "Seperator": "\uf444",
    "Prompt": "\ue691",
    "Transient": "\uf061"
  },
  "final_space": true,
  "transient_prompt": {
    "background": "transparent",
    "foreground": "p:transient",
    "template": "{{ .Var.Transient }} "
  },
  "blocks": [
    {
      "type": "prompt",
      "alignment": "left",
      "segments": [
        {
          "type": "path",
          "style": "plain",
          "foreground": "p:path",
          "template": "(\ue5fe {{ .Path }})",
          "options": {
            "folder_icon": "\ue5fe",
            "folder_separator_icon": " / ",
            "home_icon": "\uf015",
            "style": "folder"
          }
        },
        {
          "type": "git",
          "style": "plain",
          "foreground": "p:git",
          "template": " <p:seperator>{{ .Var.Seperator }}</> ({{ .HEAD }})",
          "options": {
            "branch_icon": "\ue725 ",
            "cherry_pick_icon": "\ue29b ",
            "commit_icon": "\uf417 ",
            "fetch_status": false,
            "fetch_upstream_icon": false,
            "merge_icon": "\ue727 ",
            "no_commits_icon": "\uf0c3 ",
            "rebase_icon": "\ue728 ",
            "revert_icon": "\uf0e2 ",
            "tag_icon": "\uf412 "
          }
        }
      ]
    },
    {
      "type": "prompt",
      "alignment": "left",
      "segments": [
        {
          "type": "text",
          "style": "plain",
          "foreground": "p:prompt",
          "template": " {{ .Var.Prompt }}"
        }
      ]
    }
  ]
}
